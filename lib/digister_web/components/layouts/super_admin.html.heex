<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Super Admin" suffix=" · Digister" phx-no-format>{assigns[:page_title]}</.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
  </head>
  <body class="bg-gray-50 min-h-screen flex">

    <%!-- Sidebar --%>
    <aside class="w-52 bg-white border-r border-gray-200 flex-shrink-0 flex flex-col min-h-screen fixed top-0 left-0 z-20">

      <%!-- Logo --%>
      <div class="px-5 py-5 border-b border-gray-100">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg digister-logo-bg flex items-center justify-center flex-shrink-0">
            <svg width="16" height="16" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="4" width="8" height="8" rx="1.5" fill="white" fill-opacity="0.9"/>
              <rect x="16" y="4" width="8" height="8" rx="1.5" fill="white" fill-opacity="0.7"/>
              <rect x="4" y="16" width="8" height="8" rx="1.5" fill="white" fill-opacity="0.7"/>
              <rect x="16" y="16" width="8" height="8" rx="1.5" fill="white" fill-opacity="0.5"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-bold text-gray-900 leading-tight">Digisters</p>
            <p class="text-xs text-gray-400 leading-tight">for RealOffice</p>
          </div>
        </div>
      </div>

      <%!-- Navigation --%>
      <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

        <p class="px-2 pt-1 pb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Workspace</p>

        <a href={~p"/digisters/superadmin"} class={[
          "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
          (if assigns[:active_nav] == :dashboard,
            do: "bg-indigo-50 text-indigo-600",
            else: "text-gray-500 hover:text-gray-900 hover:bg-gray-100")
        ]}>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Dashboard
        </a>

        <a href={~p"/digisters/superadmin/companies"} class={[
          "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
          if(assigns[:active_nav] == :companies,
            do: "bg-indigo-50 text-indigo-600",
            else: "text-gray-500 hover:text-gray-900 hover:bg-gray-100")
        ]}>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          Companies
        </a>

        <a href={~p"/digisters/superadmin/users"} class={[
          "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
          if(assigns[:active_nav] == :users,
            do: "bg-indigo-50 text-indigo-600",
            else: "text-gray-500 hover:text-gray-900 hover:bg-gray-100")
        ]}>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          Users
        </a>

        <a href={~p"/digisters/superadmin/registers"} class={[
          "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
          if(assigns[:active_nav] == :registers,
            do: "bg-indigo-50 text-indigo-600",
            else: "text-gray-500 hover:text-gray-900 hover:bg-gray-100")
        ]}>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
          </svg>
          Registers
        </a>

        <a href={~p"/digisters/superadmin/registers/new"} class={[
          "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
          if(assigns[:active_nav] == :new_register,
            do: "bg-indigo-50 text-indigo-600",
            else: "text-gray-500 hover:text-gray-900 hover:bg-gray-100")
        ]}>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          New Register
        </a>

        <a href={~p"/digisters/superadmin/templates"} class={[
          "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
          if(assigns[:active_nav] == :templates,
            do: "bg-indigo-50 text-indigo-600",
            else: "text-gray-500 hover:text-gray-900 hover:bg-gray-100")
        ]}>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          Templates
        </a>

        <a href={~p"/digisters/superadmin/bin"} class={[
          "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
          if(assigns[:active_nav] == :bin,
            do: "bg-indigo-50 text-indigo-600",
            else: "text-gray-500 hover:text-gray-900 hover:bg-gray-100")
        ]}>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Bin
        </a>

      </nav>

      <%!-- User info at bottom with dropup --%>
      <div class="px-4 py-4 border-t border-gray-100 relative" x-data="{ open: false }">

        <%!-- Dropup menu --%>
        <div
          x-show="open"
          x-transition:enter="transition ease-out duration-100"
          x-transition:enter-start="opacity-0 translate-y-1"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-75"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 translate-y-1"
          @click.outside="open = false"
          class="absolute bottom-full left-3 right-3 mb-2 bg-white border border-gray-200 rounded-xl shadow-lg py-1 z-50"
          style="display: none;"
        >
          <a href={~p"/digisters/superadmin/profile"} class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Profile
          </a>
          <a href={~p"/digisters/superadmin/settings"} class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Settings
          </a>
          <div class="border-t border-gray-100 my-1"></div>
          <form action={~p"/users/log-out"} method="post">
            <input type="hidden" name="_method" value="delete" />
            <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
            <button type="submit" class="w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              Sign out
            </button>
          </form>
        </div>

        <%!-- Trigger row --%>
        <button @click="open = !open" class="w-full flex items-center justify-between group">
          <div class="flex items-center gap-2.5 min-w-0">
            <div class="w-8 h-8 rounded-full bg-gray-200 flex-shrink-0 overflow-hidden">
              <%= if assigns[:current_scope] && assigns.current_scope.user && assigns.current_scope.user.avatar do %>
                <img src={"data:#{assigns.current_scope.user.avatar_content_type};base64,#{Base.encode64(assigns.current_scope.user.avatar)}"}
                  class="w-8 h-8 object-cover" />
              <% else %>
                <svg class="w-8 h-8 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                </svg>
              <% end %>
            </div>
            <div class="min-w-0 text-left">
              <p class="text-xs font-semibold text-gray-800 truncate">
                {if assigns[:current_scope] && assigns.current_scope.user,
                  do: (assigns.current_scope.user.username || assigns.current_scope.user.email |> String.split("@") |> List.first()),
                  else: "Admin"}
              </p>
              <p class="text-xs text-gray-400">Super Admin</p>
            </div>
          </div>
          <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform" x-bind:class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4M8 15l4 4 4-4" />
          </svg>
        </button>

      </div>

    </aside>

    <%!-- Main content area --%>
    <div class="flex-1 ml-52 flex flex-col min-h-screen">

      <%!-- Top bar --%>
      <header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between flex-shrink-0 sticky top-0 z-10">
        <div class="flex items-center gap-2 text-sm text-gray-500">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span id="sa-datetime"></span>
        </div>
        <button class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
        </button>
      </header>

      <%!-- Flash --%>
      <DigisterWeb.Layouts.flash_group flash={@flash} />

      <%!-- Page content --%>
      <main class="flex-1 p-6 flex flex-col">
        {@inner_content}
      </main>

    </div>

  </body>
</html>
